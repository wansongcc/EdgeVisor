{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "dllama chat (matmul views)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/dllama",
      "args": [
        "chat",
        "--model", "${workspaceFolder}/models/qwen3_8b_q40/dllama_model_qwen3_8b_q40.m",
        "--tokenizer", "${workspaceFolder}/models/qwen3_8b_q40/dllama_tokenizer_qwen3_8b_q40.t",
        "--buffer-float-type", "q80",
        "--nthreads", "48",
        "--max-seq-len", "4096"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "environment": [
        { "name": "ASAN_OPTIONS", "value": "abort_on_error=1:fast_unwind_on_malloc=0:detect_leaks=1" },
        { "name": "DLLAMA_DEBUG_MATMUL_VIEWS", "value": "1" },
        { "name": "DLLAMA_DEBUG_MATMUL_VIEWS_LIMIT", "value": "50" },
        { "name": "DLLAMA_DEBUG_MATMUL_VIEWS_FILTER", "value": "final_matmul_logits" }
      ],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true },
        { "description": "Set disassembly flavor to intel", "text": "-gdb-set disassembly-flavor intel", "ignoreFailures": true }
      ]
    },
    {
      "name": "dllama chat",
      "type": "cppdbg",
      "request": "launch",
      "program": "/workspace/dllama/distributed-llama/dllama",
      "args": [
        "chat",
        "--model", "models/qwen3_8b_q40/dllama_model_qwen3_8b_q40.m",
        "--tokenizer", "models/qwen3_8b_q40/dllama_tokenizer_qwen3_8b_q40.t",
        "--buffer-float-type", "q80",
        "--nthreads", "48",
        "--max-seq-len", "2048",
      ],
      "cwd": "/workspace/distributed-llama",
      "stopAtEntry": true,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "environment": [
        { "name": "ASAN_OPTIONS", "value": "abort_on_error=1:fast_unwind_on_malloc=0:detect_leaks=1" },
      ],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true },
        { "description": "Set disassembly flavor to intel", "text": "-gdb-set disassembly-flavor intel", "ignoreFailures": true }
      ]
    },
    {
      "name": "dllama Inference (ASan)",
      "type": "cppdbg",
      "request": "launch",
      "program": "/workspace/dllama/distributed-llama/dllama",
      "args": [
        "inference",
        "--interactive",
        "--prompt", "The capital of France is",
        "--steps", "256",
        "--model", "/workspace/dllama/distributed-llama/models/llama3.2_3b_instruct_q40/dllama_model_llama3.2-3b-instruct_q40.m",
        "--tokenizer", "/workspace/dllama/distributed-llama/models/llama3.1_instruct_q40/dllama_tokenizer_llama_3_1.t",
        "--buffer-float-type", "q80",
        // "--kv-redundancy", "2",
        "--nthreads", "2",
        "--max-seq-len", "2048",
        "--enable-plan-barrier",
        "--enable-stage-full-weights",
        // "--enable-kv-aggregate",
        // "--enable-pp-migration",
        // "--runtime-redundant-boundary-layers", "4",
        // "--runtime-primary-skip-layers", "14",
        // "--net-turbo",
        "--benchmark",
        "--workers", "rpi-trixie5:9999", 
        "--ratios", "1:1"
      ],
      "cwd": "/workspace/distributed-llama",
      "stopAtEntry": true,
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "environment": [
        { "name": "ASAN_OPTIONS", "value": "abort_on_error=1:fast_unwind_on_malloc=0:detect_leaks=1" },
        // { "name": "DLLAMA_STAGE_FULL_WEIGHTS", "value": "1" },
        // { "name": "DLLAMA_DEBUG_WEIGHT_RANGES", "value": "0" },
        { "name": "DLLAMA_ATT_FULL_BUFFERS", "value": "1" },
        // { "name": "DLLAMA_DEBUG_SLICE_PARAMS", "value": "0" },
        // { "name": "DLLAMA_DEBUG_SLICE_PARAMS_FWD", "value": "0" },
        // { "name": "DLLAMA_DEBUG_SLICE_PARAMS_FWD_REPEAT", "value": "0" },
        { "name": "DLLAMA_ENABLE_PLAN_BARRIER", "value": "1" },
        { "name": "DLLAMA_PLAN_CTRL_SOCKET", "value": "/tmp/dllama_plan.sock" },
        // Build-time graph dump (uneven builder): print ops for layer 0 only.
        { "name": "DLLAMA_DEBUG_GRAPH_BUILD", "value": "1" },
        { "name": "DLLAMA_DEBUG_GRAPH_BUILD_LAYER", "value": "0" },
        // Optional: set to node index (0/1/...) to reduce logs. -1 means all nodes.
        { "name": "DLLAMA_DEBUG_GRAPH_BUILD_NODE", "value": "-1" },
        // { "name": "DLLAMA_SEG_BUILD_PRINT", "value": "1" },
        // { "name": "DLLAMA_RUNTIME_PLAN_PRINT", "value": "1"},
        // { "name": "DLLAMA_SEG_RUNTIME_PRINT"  , "value": "1" }, 
        // { "name": "DLLAMA_ASYNC_KV_COLLECT_LAYER", "value": "15" },
        // { "name": "DLLAMA_MIGRATION_OP_TRACE", "value": "1" },
        // { "name": "DLLAMA_MIGRATION_LAYER_LIST", "value": "13,12,11,10" }
        // { "name": "DLLAMA_DEBUG_TP_RANGES_LAYER_SPAN", "value": "2" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_SHIFT", "value": "1" },
        // { "name": "DLLAMA_ENABLE_KV_REDUNDANCY_DURING_MIGRATION", "value": "1" },
        // { "name": "DLLAMA_SYNC_TRACE", "value": "1" },
        // { "name": "DLLAMA_SYNC_TRACE_ALL_THREADS", "value": "1" },
        { "name": "DLLAMA_DEBUG_ATT", "value": "1" },
        { "name": "DLLAMA_DEBUG_ATT_FILTER", "value": "block_multihead_att"},
        { "name": "DLLAMA_DEBUG_ATT_LIMIT", "value": "24" },
        { "name": "DLLAMA_DEBUG_ATT_HEAD", "value": "0" },
        { "name": "DLLAMA_DEBUG_ATT_QK", "value": "1" },
        { "name": "DLLAMA_DEBUG_ATT_QK_DIMS", "value": "16" },
        { "name": "DLLAMA_DEBUG_ATT_QK_TOPK", "value": "3" },
        { "name": "DLLAMA_DEBUG_ATT_QK_POS", "value": "4" },

        // // Matmul IO debug: verify whether Q head6/7 slice [768..1024) is produced.
        // { "name": "DLLAMA_DEBUG_MATMUL_IO", "value": "1" },
        // { "name": "DLLAMA_DEBUG_MATMUL_IO_FILTER", "value": "block_matmul_q" },
        // { "name": "DLLAMA_DEBUG_MATMUL_IO_LIMIT", "value": "0" },
        // { "name": "DLLAMA_DEBUG_MATMUL_IO_OUT_OFFSET", "value": "768" },
        // { "name": "DLLAMA_DEBUG_MATMUL_IO_OUT_LEN", "value": "256" },

        // // Print KV cache values per KV-head owned by each node (CPU attention only)
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD", "value": "1" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_FILTER", "value": "block_multihead_att" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_DIMS", "value": "8" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_LIMIT", "value": "64" },
        // // Print redundant heads too (global kvHead numbering)
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_GLOBAL", "value": "1" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_KVHEADS", "value": "2-3" },
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_POS", "value": "32" },
        // // Needed for SHIFT logging when redundancy sets dstColStartUnit=0
        // { "name": "DLLAMA_DEBUG_KVCACHE_PER_HEAD_HEADDIM", "value": "128" },
        // { "name": "DLLAMA_DEBUG_ATT_SCORES", "value": "1" },
        // { "name": "kvcache_debug", "value": "1" },
        // { "name": "DLLAMA_KV_AGGREGATE", "value": "1" },
        // { "name": "DLLAMA_KV_AGGREGATE_IN_FULL", "value": "1" },
        // { "name": "DLLAMA_KV_AGGREGATE_PROOF", "value": "1" },
        // { "name": "DLLAMA_KV_AGGREGATE_PROOF_ALL_BATCHES", "value": "1" }
        // { "name": "DLLAMA_DEBUG_KV_RANGE", "value": "1" },
        
        
      ],
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true },
        { "description": "Set disassembly flavor to intel", "text": "-gdb-set disassembly-flavor intel", "ignoreFailures": true }
      ]
    },
    {
